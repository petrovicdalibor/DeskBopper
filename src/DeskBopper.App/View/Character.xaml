<UserControl x:Class="DeskBopper.App.View.Character"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="200" Height="220"
             d:DesignWidth="200" d:DesignHeight="220">
    <!-- Vector mascot. The element named "Head" carries a TransformGroup (rotate +
         translate) which CharacterAnimator drives per frame. RenderTransformOrigin
         is the neck (bottom-centre of the head) so the bob pivots naturally. -->
    <Canvas Width="200" Height="220">

        <!-- Soft ground shadow -->
        <Ellipse Canvas.Left="50" Canvas.Top="196" Width="100" Height="18"
                 Fill="#33000000"/>

        <!-- Body (static) -->
        <Ellipse Canvas.Left="55" Canvas.Top="120" Width="90" Height="90"
                 Fill="#4C6EF5"/>
        <!-- Neck -->
        <Rectangle Canvas.Left="88" Canvas.Top="108" Width="24" Height="26"
                   RadiusX="10" RadiusY="10" Fill="#4C6EF5"/>

        <!-- Head group (animated) -->
        <Grid x:Name="Head" Canvas.Left="40" Canvas.Top="8"
              Width="120" Height="120"
              RenderTransformOrigin="0.5,1.0">
            <Grid.RenderTransform>
                <TransformGroup>
                    <RotateTransform x:Name="HeadRotate" Angle="0"/>
                    <TranslateTransform x:Name="HeadOffset" X="0" Y="0"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Canvas Width="120" Height="120">
                <!-- Headphone band arcing over the top -->
                <Path Stroke="#2B2D42" StrokeThickness="9" StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 12,60 A 48,52 0 0 1 108,60"/>

                <!-- Head -->
                <Ellipse Canvas.Left="16" Canvas.Top="14" Width="88" Height="88"
                         Fill="#6BA7FF"/>

                <!-- Ear cups -->
                <Rectangle Canvas.Left="4" Canvas.Top="46" Width="22" Height="36"
                           RadiusX="9" RadiusY="9" Fill="#2B2D42"/>
                <Rectangle Canvas.Left="94" Canvas.Top="46" Width="22" Height="36"
                           RadiusX="9" RadiusY="9" Fill="#2B2D42"/>

                <!-- Eyes -->
                <Ellipse Canvas.Left="44" Canvas.Top="50" Width="13" Height="16" Fill="#1B1B2F"/>
                <Ellipse Canvas.Left="66" Canvas.Top="50" Width="13" Height="16" Fill="#1B1B2F"/>
                <!-- Eye highlights -->
                <Ellipse Canvas.Left="47" Canvas.Top="53" Width="4" Height="5" Fill="#FFFFFF"/>
                <Ellipse Canvas.Left="69" Canvas.Top="53" Width="4" Height="5" Fill="#FFFFFF"/>

                <!-- Smile -->
                <Path Stroke="#1B1B2F" StrokeThickness="4" StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 50,78 Q 61,88 72,78"/>
            </Canvas>
        </Grid>
    </Canvas>
</UserControl>
