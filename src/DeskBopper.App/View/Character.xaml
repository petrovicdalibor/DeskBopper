<UserControl x:Class="DeskBopper.App.View.Character"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="120" Height="152"
             d:DesignWidth="120" d:DesignHeight="152">
    <!-- Vector mascot: smaller build, with legs and shades. The element named "Head"
         carries a TransformGroup (rotate + translate) which CharacterAnimator drives per
         frame. RenderTransformOrigin is the neck (bottom-centre) so the bob pivots there.
         The Viewbox scales the 150x190 artwork down to the control size. -->
    <Viewbox Stretch="Uniform">
    <Canvas Width="150" Height="190">

        <!-- Soft ground shadow -->
        <Ellipse Canvas.Left="45" Canvas.Top="174" Width="60" Height="12"
                 Fill="#33000000"/>

        <!-- Left leg + foot (animated as one, pivoting at the hip) -->
        <Canvas x:Name="LeftLeg" Canvas.Left="60" Canvas.Top="146"
                Width="9" Height="32" RenderTransformOrigin="0.5,0.06">
            <Canvas.RenderTransform>
                <TransformGroup>
                    <RotateTransform x:Name="LeftLegRotate" Angle="0"/>
                    <TranslateTransform x:Name="LeftLegOffset" Y="0"/>
                </TransformGroup>
            </Canvas.RenderTransform>
            <Rectangle x:Name="LeftLegFill" Width="9" Height="26" RadiusX="4.5" RadiusY="4.5" Fill="#3B57C4"/>
            <Ellipse Canvas.Left="-6" Canvas.Top="22" Width="22" Height="10" Fill="#2B2D42"/>
        </Canvas>

        <!-- Right leg + foot -->
        <Canvas x:Name="RightLeg" Canvas.Left="81" Canvas.Top="146"
                Width="9" Height="32" RenderTransformOrigin="0.5,0.06">
            <Canvas.RenderTransform>
                <TransformGroup>
                    <RotateTransform x:Name="RightLegRotate" Angle="0"/>
                    <TranslateTransform x:Name="RightLegOffset" Y="0"/>
                </TransformGroup>
            </Canvas.RenderTransform>
            <Rectangle x:Name="RightLegFill" Width="9" Height="26" RadiusX="4.5" RadiusY="4.5" Fill="#3B57C4"/>
            <Ellipse Canvas.Left="-6" Canvas.Top="22" Width="22" Height="10" Fill="#2B2D42"/>
        </Canvas>

        <!-- Hoodie torso: rounded body with soft shoulders, tapering to the waist.
             Drawn before the head group so the head overlaps the top (no neck gap). -->
        <Path x:Name="BodyFill" Fill="#4C6EF5"
              Data="M 52,156 C 45,150 45,118 47,102 C 48,92 58,80 75,80
                    C 92,80 102,92 103,102 C 105,118 105,150 98,156
                    C 88,161 62,161 52,156 Z"/>

        <!-- Hood collar behind the neck -->
        <Rectangle x:Name="CollarFill" Canvas.Left="53" Canvas.Top="82" Width="44" Height="20"
                   RadiusX="10" RadiusY="10" Fill="#3B57C4"/>

        <!-- Drawstrings with toggles -->
        <Line X1="72" Y1="99" X2="71" Y2="120" Stroke="#EAEEF7" StrokeThickness="2.5"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        <Line X1="79" Y1="99" X2="80" Y2="120" Stroke="#EAEEF7" StrokeThickness="2.5"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        <Ellipse Canvas.Left="68" Canvas.Top="119" Width="6" Height="6" Fill="#EAEEF7"/>
        <Ellipse Canvas.Left="77" Canvas.Top="119" Width="6" Height="6" Fill="#EAEEF7"/>

        <!-- Front kangaroo pocket -->
        <Rectangle x:Name="PocketFill" Canvas.Left="56" Canvas.Top="126" Width="38" Height="20"
                   RadiusX="9" RadiusY="9" Fill="#3B57C4"/>
        <Path Stroke="#000000" StrokeThickness="1.5" Opacity="0.18"
              Data="M 60,129 L 90,129"/>

        <!-- Head group (animated) -->
        <Grid x:Name="Head" Canvas.Left="25" Canvas.Top="6"
              Width="100" Height="96"
              RenderTransformOrigin="0.5,1.0">
            <Grid.RenderTransform>
                <TransformGroup>
                    <RotateTransform x:Name="HeadRotate" Angle="0"/>
                    <TranslateTransform x:Name="HeadOffset" X="0" Y="0"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Canvas Width="100" Height="96">
                <!-- Headphone band arcing over the top -->
                <Path Stroke="#23243A" StrokeThickness="7" StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 12,48 A 38,40 0 0 1 88,48"/>

                <!-- Head -->
                <Ellipse x:Name="HeadFill" Canvas.Left="17" Canvas.Top="12" Width="66" Height="66"
                         Fill="#6BA7FF"/>

                <!-- Glossy highlight on the head -->
                <Ellipse Canvas.Left="28" Canvas.Top="17" Width="32" Height="22" Opacity="0.4">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.35,0.3" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Ear cups with a cyan accent -->
                <Rectangle Canvas.Left="4" Canvas.Top="36" Width="17" Height="32"
                           RadiusX="8" RadiusY="8" Fill="#23243A"/>
                <Rectangle Canvas.Left="79" Canvas.Top="36" Width="17" Height="32"
                           RadiusX="8" RadiusY="8" Fill="#23243A"/>
                <Rectangle Canvas.Left="8" Canvas.Top="44" Width="4" Height="16"
                           RadiusX="2" RadiusY="2" Fill="#66E7FF" Opacity="0.75"/>
                <Rectangle Canvas.Left="88" Canvas.Top="44" Width="4" Height="16"
                           RadiusX="2" RadiusY="2" Fill="#66E7FF" Opacity="0.75"/>

                <!-- Sunglasses: two lenses, a bridge, and temple arms to the cups -->
                <Rectangle Canvas.Left="10" Canvas.Top="43" Width="16" Height="3.5"
                           RadiusX="1.5" RadiusY="1.5" Fill="#15151F"/>
                <Rectangle Canvas.Left="74" Canvas.Top="43" Width="16" Height="3.5"
                           RadiusX="1.5" RadiusY="1.5" Fill="#15151F"/>
                <Rectangle Canvas.Left="46" Canvas.Top="40" Width="8" Height="4" Fill="#15151F"/>
                <Rectangle Canvas.Left="23" Canvas.Top="36" Width="24" Height="17"
                           RadiusX="7" RadiusY="7">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                            <GradientStop Color="#33344B" Offset="0"/>
                            <GradientStop Color="#0C0C15" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Canvas.Left="53" Canvas.Top="36" Width="24" Height="17"
                           RadiusX="7" RadiusY="7">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                            <GradientStop Color="#33344B" Offset="0"/>
                            <GradientStop Color="#0C0C15" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Subtle lens glint -->
                <Polygon Points="28,49 34,38 38,38 32,49" Fill="#FFFFFF" Opacity="0.30"/>
                <Polygon Points="58,49 64,38 68,38 62,49" Fill="#FFFFFF" Opacity="0.30"/>

                <!-- Cool smirk -->
                <Path Stroke="#12121C" StrokeThickness="3.5" StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 42,62 Q 52,68 62,60"/>
            </Canvas>
        </Grid>
    </Canvas>
    </Viewbox>
</UserControl>
